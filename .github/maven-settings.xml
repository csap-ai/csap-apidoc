<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maven settings used exclusively by the release workflow.
  Credentials are injected at runtime via environment variables:
    OSSRH_USERNAME / OSSRH_PASSWORD
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0
                              https://maven.apache.org/xsd/settings-1.2.0.xsd">

  <servers>
    <!-- Legacy OSSRH (Nexus 2) — used by nexus-staging-maven-plugin -->
    <server>
      <id>ossrh</id>
      <username>${env.OSSRH_USERNAME}</username>
      <password>${env.OSSRH_PASSWORD}</password>
    </server>

    <!-- Sonatype Central Portal — used by central-publishing-maven-plugin -->
    <server>
      <id>central</id>
      <username>${env.OSSRH_USERNAME}</username>
      <password>${env.OSSRH_PASSWORD}</password>
    </server>

    <!-- Snapshot repository (legacy path) -->
    <server>
      <id>sonatype-nexus-snapshots</id>
      <username>${env.OSSRH_USERNAME}</username>
      <password>${env.OSSRH_PASSWORD}</password>
    </server>
  </servers>

</settings>
